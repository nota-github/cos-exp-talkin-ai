{
  "name": "@talkin-ai/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:electron:watch": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "node --experimental-strip-types --import ./tests/register-ts-loader.mjs --test tests/*.test.ts",
    "validate:story-1.1": "npm run test",
    "validate:story-1.2": "npm run test",
    "validate:story-1.3": "npm run test",
    "validate:story-1.4": "npm run test",
    "validate:story-1.5": "npm run test",
    "validate:story-2.1": "npm run test",
    "validate:story-2.2": "npm run test",
    "validate:story-3.1": "npm run test",
    "validate:story-3.2": "npm run test",
    "validate:story-3.3": "npm run test",
    "validate:story-3.4": "npm run test",
    "validate:story-3.5": "npm run test",
    "validate:story-5.3": "npm run test",
    "validate:story-5.4": "npm run test"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.2.74",
    "@types/react-dom": "^18.2.24",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.10"
  }
}
